
export BASH_SILENCE_DEPRECATION_WARNING=1
readonly Mochila="-/MasriaBashGame/Masria/home/Mochila"

# ============================================
# MasriaBashGame - Música de fondo (Linux/macOS)
# ============================================

MASRIA_MUSIC_PID_FILE="/tmp/masria_music_pid"
MASRIA_MUSIC_FILE="$HOME/MasriaBashGame/musica/masria.mp3"

# Función para iniciar música según el sistema
masria_start_music() {
    # Verificar si ya hay música sonando
    if [[ -f "$MASRIA_MUSIC_PID_FILE" ]]; then
        local old_pid=$(cat "$MASRIA_MUSIC_PID_FILE")
        if kill -0 "$old_pid" 2>/dev/null; then
            return 0  # Ya está sonando
        fi
        rm -f "$MASRIA_MUSIC_PID_FILE"
    fi
    
    # Verificar que el archivo existe
    if [[ ! -f "$MASRIA_MUSIC_FILE" ]]; then
        return 1
    fi
    
    # Detectar sistema operativo y usar el reproductor adecuado
    case "$(uname -s)" in
        Darwin*)
            # macOS: usar afplay con bucle while
            (while true; do afplay "$MASRIA_MUSIC_FILE"; done) &
            local pid=$!
            ;;
        Linux*)
            # Linux: usar mpv o mplayer
            if command -v mpv &> /dev/null; then
                mpv --no-video --loop=inf --quiet "$MASRIA_MUSIC_FILE" &
                local pid=$!
            elif command -v mplayer &> /dev/null; then
                mplayer -loop 0 -quiet "$MASRIA_MUSIC_FILE" &
                local pid=$!
            else
                return 1
            fi
            ;;
        *)
            return 1
            ;;
    esac
    
    echo "$pid" > "$MASRIA_MUSIC_PID_FILE"
    export MASRIA_MUSIC_PID="$pid"
    echo "🎵 Música iniciada (PID: $pid)"
}

# Función para detener música
masria_stop_music() {
    if [[ -f "$MASRIA_MUSIC_PID_FILE" ]]; then
        local pid=$(cat "$MASRIA_MUSIC_PID_FILE")
        if kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null
            # En macOS, asegurar también killall por si quedan procesos
            [[ "$(uname -s)" == "Darwin" ]] && killall afplay 2>/dev/null
            echo "🎵 Música detenida"
        fi
        rm -f "$MASRIA_MUSIC_PID_FILE"
        unset MASRIA_MUSIC_PID
    fi
}

# Exit personalizado
exit() {
    masria_stop_music
    builtin exit "$@"
}

# Iniciar música automáticamente
if [[ -d "$HOME/MasriaBashGame" ]] && [[ -t 0 ]]; then
    masria_start_music
fi

# Alias útiles
alias masria-music-stop='masria_stop_music'
alias masria-music-start='masria_start_music'

move() {
    local destino="$1"
    
    # Sin argumento, mostrar ayuda
    if [ -z "$destino" ]; then
        echo " --- 🏰 --- Ubicaciones disponibles: (Ejemplo move 'lugar')"
        ls -d */ | sed 's|/$||'
        #ls -d "$GAME_BASE"/*/ 2>/dev/null | xargs -n 1 basename
        return 0
    fi
    
    #CONTROL DE NO SALIRSE DEL JUEGO:
    dir=$(pwd)
    c=$1

    nivel=$(tr -dc '/' <<<"$dir" | awk '{ print length; }')

    # nivel 2 home/usuario
    # nivel 3 carpeta juego
    # nivel 4 carpeta Masria
    # nivel 5 Valentia..
    # maximo hay nivel 7.



    if [[ $nivel -eq 4 ]] && [[ $c == *..* ]] 
    then 
        echo "No puedes salir del Mundo de Masria"
        return 1
    fi

    if [[ $nivel -eq 5 ]] && [[ $c == *../..* ]] 
    then 
        echo "No puedes salir del Mundo de Masria"
        return 1
    fi

    if [[ $nivel -eq 6 ]] && [[ $c == *../../..* ]] 
    then 
        echo "No puedes salir del Mundo de Masria"
        return 1
    fi

    if [[ $nivel -eq 7 ]] && [[ $c == *../../../..* ]] 
    then 
        echo "No puedes salir del Mundo de Masria"
        return 1
    fi


    ## si el argumento de cd empieza por /,  no dejar si no escribe una ruta completa hasta Masria ;)

    if [[ $c == /* ]]
    then	
        if [[ $c == *Masria* ]]
        then 	echo ""
        else 	echo "No puedes salirte del Juego ahora!!"
            return 1
        fi
    fi

    if [[ $c == *Guybrush* ]] 
    then 
        echo "No puedes ver las cosas personales de Guybrush"
        return 1
    fi

    if [[ $c == *Mochila* ]] 
    then 
        echo 'No puedes entrar en tu Mochila! No cabes!!! Prueba: ls $Mochila'
        return 1

    fi

    if [[ $c == *Frontera* ]]
    then 
      $HOME/MasriaBashGame/Masria/Frontera/.sephiroth.sh &

      case "$(uname -s)" in
        Linux*)
            # En Linux, buscar visores comunes
            if [[ -f /usr/bin/eog ]]; then
                eog "$HOME/MasriaBashGame/Masria/Frontera/sephiroth.jpg" &
            elif [[ -f /usr/bin/eom ]]; then
                eom "$HOME/MasriaBashGame/Masria/Frontera/sephiroth.jpg" &
            elif [[ -f /usr/bin/feh ]]; then
                feh "$HOME/MasriaBashGame/Masria/Frontera/sephiroth.jpg" &
            elif [[ -f /usr/bin/xdg-open ]]; then
                xdg-open "$HOME/MasriaBashGame/Masria/Frontera/sephiroth.jpg" &
            else
                echo "No se encontró un visor de imágenes. Instala eog, eom o feh."
            fi
            ;;
        Darwin*)
            # En macOS, usar open (nativo)
            open "$HOME/MasriaBashGame/Masria/Frontera/sephiroth.jpg" &
            ;;
        *)
            echo "Sistema operativo no soportado para mostrar imágenes"
            ;;
    esac
        
    fi

    if [[ $nivel -le 3 ]]
    then 
        # new game
        # continue_game
        # o Ha conseguido salirse de algún modo.
        ubicacion=$(cat $HOME/MasriaBashGame/saved_game)
        cd $ubicacion && cat .escenario
    fi

    # Parece correcto: Intentar cambiar al directorio
    if [ -d "$destino" ]; then
        builtin cd "$destino"
        
        # Mostrar escenario
        if [ -f ".escenario" ]; then
            clear
           
            cat .escenario
         
        fi
    else
        echo "❌ No existe '$destino'"
        return 1
    fi
    


    #GRABAR PARTIDA EN CADA MOVIMIENTO
    saved_game=$(pwd)
    echo $saved_game > $HOME/MasriaBashGame/saved_game

    # Actualizar prompt para mostrar ubicación
    #export PS1="\[\033[01;32m\]Claud@World\[\033[00m\] : \[\033[01;34m\]\w\[\033[00m\] > "
    
}

mv(){
    if [[ -d $1 ]]
    then
        echo "❌ No puedes mover un lugar o ciudad del juego."
        return 1
    fi
     /bin/mv $@
}

cat(){

    if [[ "$#" -eq 0 ]]
    then echo "[el comando ejecutado necesita mínimo un argumento]"
    else 
        
        ## hay un argumento.   
        # hacemos cat si es un fichero.

        if [[ -f $1 ]]
        then
            /bin/cat $1
        else
            echo "[Error, $1 no existe o no es un fichero (objeto)"
        fi	
    fi
}

# Redefine ls para ocultar .escenarios
ls() {
    # Si es "ls -a" o "ls --all"
    if [[ "$*" == *"cosas_de"* ]]
    then
     echo "No puedes ver las cosas de Guybrush!"
     return 1
    fi

    if [[ "$*" == *"-a"* ]] || [[ "$*" == *"--all"* ]] || [[ "$*" == *"-la"* ]]; then
        # Ejecutar el ls real pero filtrar .escenario
        command ls --color "$@" | grep -v "^\.escenario*" | grep -v "^\.scene" | grep -v "Mochila"
    else
        # Comportamiento normal
        command ls --color "$@" | grep -v "Mochila"
    fi
}

cp() {
    # Si es "ls -a" o "ls --all"
    if [[ "$*" == *"cosas_de"* ]]
    then
     echo "No puedes robarle el pergamino a Guybrush! Buen intento..."
     return 1
    else /bin/cp $@
    fi
}
touch() { echo "No puedes crear tus propios objetos. Yo soy más hacker que tú."; }

exit() {
    # Preguntar si salir
    read -p "Has introducido el comando para salir del juego. 
    El juego tiene función de autoguardado.
    ¿Quieres salir del juego ahora? [S/N] " salir

    case $salir in
        [Ss]*)
            echo "Guardando partida antes de salir..."
            # Aquí iría el código para autoguardar
            # Ejemplo: guardar_partida
            echo "¡Hasta pronto!"
            masria_stop_music
            builtin exit 0
            ;;
        [Nn]*)
            echo "Continuando con el juego..."
            return 0
            ;;
        *)
            echo "Respuesta no válida. Por favor, responde S o N."
            ;;
    esac
}

